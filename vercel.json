{
    "version": 2,
    "builds": [
        {
            "src": "**/*.php",
            "use": "vercel-php@0.7.2"
        },
        {
            "src": "**/*.+(png|jpg|jpeg|gif|svg|ico|css|js|webp|avif)",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(index|sobre|projetos)",
            "dest": "/$1.php"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/404.php",
            "status": 404
        }
    ]
}